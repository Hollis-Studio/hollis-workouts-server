# ============================================================
# Hollis Workouts Server — Environment Variables
# Copy to .env and fill in values. Never commit .env.
# ============================================================

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/hollis_workouts

# Identity Service (auth delegation)
# URL of the running Hollis Identity Service
IDENTITY_SERVICE_URL=http://localhost:3001

# JWT secret for local HS256 verification (until JWKS is live)
# Generate with: openssl rand -base64 32
IDENTITY_JWT_SECRET=change_me_at_least_32_chars_long_placeholder

# Audience claim this service expects in incoming JWTs
AUDIENCE=hollis-workouts

# Server
PORT=3002
LOG_LEVEL=info

# Node environment
NODE_ENV=development

# ------------------------------------------------------------
# Optional / production (read directly in src/lib/prisma.ts)
# ------------------------------------------------------------
# RDS CA bundle (file path OR raw PEM). When set, Postgres TLS cert validation
# is enabled (rejectUnauthorized defaults to true). REQUIRED for production —
# without it the connection runs with cert validation DISABLED (a warning logs).
# Download: https://truststore.pki.rds.amazonaws.com/global/global-bundle.pem
# DATABASE_SSL_CA=/etc/ssl/rds/global-bundle.pem

# Override TLS cert validation. "true" enforces validation without a CA bundle
# (only if the DB presents a publicly-trusted chain); "false" disables it.
# DATABASE_SSL_REJECT_UNAUTHORIZED=true

# Set "true" to log parameterized SQL templates at debug level (values are NOT
# logged). Leave off in production.
# LOG_DB_QUERIES=false
