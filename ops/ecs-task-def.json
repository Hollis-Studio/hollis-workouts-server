{
  "_comment": "TODO(W5e/DEFERRED-audit): PLACEHOLDER — replace before deploy. Mirror hollis-health-app/server/ops/ecs-task-def.json. executionRoleArn MUST grant ssm:GetParameters / secretsmanager:GetSecretValue on the three secret ARNs below, or ECS cannot inject them and the task crashes at validateEnv(). Each secret needs its OWN distinct ARN.",
  "family": "hollis-workouts-server",
  "executionRoleArn": "PLACEHOLDER_EXECUTION_ROLE_ARN",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "containerDefinitions": [
    {
      "name": "workouts-server",
      "image": "PLACEHOLDER_ECR_IMAGE_URI",
      "portMappings": [{ "containerPort": 3002, "protocol": "tcp" }],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "3002" },
        { "name": "AUDIENCE", "value": "hollis-workouts" }
      ],
      "secrets": [
        { "name": "DATABASE_URL", "valueFrom": "PLACEHOLDER_SSM_ARN_DATABASE_URL" },
        { "name": "IDENTITY_JWT_SECRET", "valueFrom": "PLACEHOLDER_SSM_ARN_IDENTITY_JWT_SECRET" },
        { "name": "IDENTITY_SERVICE_URL", "valueFrom": "PLACEHOLDER_SSM_ARN_IDENTITY_SERVICE_URL" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/hollis-workouts-server",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
