// ============================================================================
// Hollis Workouts Server — Prisma Schema
// ============================================================================
// 13 SYNCED_COLLECTIONS + CanonicalExercise catalog + SmartReaderUsage counter
//
// Design rules:
//   - Every user-scoped model has userId String indexed (not a FK — Identity
//     Service owns User; this server is format-agnostic).
//   - IDs: id String @id — caller-provided (cuid2 or UUID). No @default(cuid()).
//   - Timestamps: createdAt DateTime + updatedAt DateTime @updatedAt.
//     No @default(now()) — set explicitly at write time in ISO UTC.
//   - Deeply nested sub-documents (set arrays, day arrays, interval arrays) are
//     stored as Json columns validated by the matching Zod schema at read/write.
//   - CanonicalExercise is NOT user-scoped (global catalog). Seed: npm run prisma:seed
// ============================================================================

generator client {
  provider = "prisma-client-js"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// 1. Gym (collection: gyms)
//    Shape: GymProfile from Workouts models.ts
//    equipmentItems stored as Json (GymEquipmentItem[]) — nested variant/weight fields
// ============================================================================

model Gym {
  id                    String   @id
  userId                String
  name                  String
  /// GymLocation { lat?, lng?, address? }
  location              Json?
  /// EquipmentType[] — Postgres text array
  equipmentTypes        String[]
  /// Specific equipment catalog IDs (e.g. 'olympic_barbell')
  equipmentIds          String[]
  /// GymEquipmentItem[] — full item config including variant, weightStackKg, etc.
  equipmentItems        Json
  /// ExerciseSelectionMode enum value
  exerciseSelectionMode String
  isActive              Boolean
  createdAt             DateTime
  updatedAt             DateTime @updatedAt

  @@index([userId])
  @@index([userId, isActive])
  @@map("gyms")
}

// ============================================================================
// 2. Program (collection: programs)
//    Shape: Program from @hollis/contracts progression/program.ts
//    schedule (ProgramDay[]) stored as Json — includes exercises[].sets[] deep nesting
// ============================================================================

model Program {
  id                String    @id
  userId            String
  name              String
  description       String?
  /// ProgramType: "linear" | "mesocycle" | "custom"
  type              String
  startDate         DateTime
  endDate           DateTime?
  durationWeeks     Int
  isActive          Boolean
  /// Int[] week numbers that are deload weeks
  deloadWeekNumbers Int[]
  deloadPercent     Float
  /// ProgramDay[] — each day has exercises[].sets[]; stored as Json blob
  schedule          Json
  schemaVersion     Int?
  createdAt         DateTime
  updatedAt         DateTime  @updatedAt
  /// Soft-delete tombstone. When set, the row is returned in list responses so
  /// clients can evict it from their local mirror, but is hidden from single GET.
  deletedAt         DateTime?

  @@index([userId])
  @@index([userId, isActive])
  @@map("programs")
}

// ============================================================================
// 3. Session / TrainingSessionLog (collection: sessions)
//    Shape: TrainingSessionLog from @hollis/contracts domain/training-session-log.ts
//    exercises (SessionExercise[]) stored as Json — includes sets[], cardioData, stretchData
// ============================================================================

model Session {
  id                 String    @id
  userId             String
  programId          String?
  programDayName     String?
  gymProfileId       String?
  startedAt          DateTime
  completedAt        DateTime?
  updatedAt          DateTime  @updatedAt
  isFreestyle        Boolean
  isSubstitution     Boolean
  /// "active" | "completed" | "abandoned"
  status             String
  /// QuestionnaireResponse — sleep, energy, HRV, etc.
  questionnaire      Json
  totalVolumeKg      Float
  durationMinutes    Float
  untrackedVolume    Float?
  /// AIOutlierLabel — broad string label from AI outlier detection
  aiOutlierLabel     String?
  schemaVersion      Int?
  /// ProgramPhase — "hypertrophy" | "strength" | "peaking" | "deload" | "maintenance"
  programPhase       String?
  /// String[] of skipped exercise IDs
  skippedExerciseIds String[]
  /// SessionExercise[] — includes sets[], cardioData, stretchData; stored as Json
  exercises          Json
  /// Soft-delete tombstone — see Program.deletedAt.
  deletedAt          DateTime?

  @@index([userId])
  @@index([userId, completedAt])
  @@index([userId, status])
  @@index([userId, startedAt])
  // Supports the ?since incremental-sync filter (where updatedAt >= …).
  @@index([userId, updatedAt])
  @@map("sessions")
}

// ============================================================================
// 4. ProgressionBaseline (collection: progressionBaselines)
//    Shape: ProgressionBaseline from @hollis-studio/contracts/progression/baseline
//    Field names match ProgressionBaselineSchema (canonicalExerciseId, not exerciseId).
//    history (BaselineEntry[]) stored as Json
// ============================================================================

model ProgressionBaseline {
  userId                        String
  /// Canonical exercise ID this baseline tracks.
  /// Primary key is composite (userId, canonicalExerciseId) — mirrors Firestore
  /// where the doc id WAS the canonicalExerciseId. No surrogate id column.
  canonicalExerciseId           String
  currentE1RM_Kg                Float
  topSetWeightKg                Float
  topSetReps                    Int
  topSetRIR                     Int
  lastUpdated                   DateTime
  /// BaselineEntry[] — history of qualifying sets; stored as Json
  history                       Json
  phaseExitE1RM_Kg              Float?
  /// Float (double precision) — stores epoch-milliseconds; Int overflows int4 (max ~2.1e9 < current epoch ~1.7e12).
  phaseExitDate                 Float?
  /// classMix { s, h, e } — stored as Json
  classMix                      Json?
  trendE1RM_Kg                  Float?
  trendTopSetWeightKg           Float?
  trendTopSetReps               Int?
  trendTopSetRIR                Int?
  missStreak                    Int?
  /// 0 | 0.05 | 0.1
  autoDeloadPercent             Float?
  plateauDeloadUntil            DateTime?
  plateauDeloadReductionPercent Float?
  lastPlateauAlertedAt          DateTime?
  schemaVersion                 Int?
  createdAt                     DateTime
  updatedAt                     DateTime  @updatedAt
  /// Soft-delete tombstone — see Program.deletedAt.
  deletedAt                     DateTime?

  @@id([userId, canonicalExerciseId])
  @@index([userId])
  // Supports the list orderBy [{ lastUpdated desc }, { canonicalExerciseId desc }].
  @@index([userId, lastUpdated])
  @@map("progression_baselines")
}

// ============================================================================
// 5. CardioBaseline (collection: cardioBaselines)
//    Shape: CardioBaseline from @hollis-studio/contracts/progression/baseline
//    Field names match CardioBaselineSchema (canonicalExerciseId, not exerciseId).
//    history (CardioBaselineEntry[]) stored as Json
// ============================================================================

model CardioBaseline {
  userId               String
  /// Canonical exercise ID this baseline tracks.
  /// Primary key is composite (userId, canonicalExerciseId) — mirrors Firestore
  /// where the doc id WAS the canonicalExerciseId. No surrogate id column.
  canonicalExerciseId  String
  bestDurationSeconds  Float
  bestDistanceKm       Float?
  bestPaceSecondsPerKm Float?
  /// bestMETs must be written explicitly as null when absent, never omitted —
  /// the app's CardioBaselineSchema requires the key present (z.number().nullable()).
  bestMETs             Float?
  lowestHRAtPace       Int?
  lastDurationSeconds  Float
  lastDistanceKm       Float?
  lastAvgSpeedKmh      Float?
  lastPaceSecondsPerKm Float?
  lastIncline          Float?
  lastResistance       Float?
  lastAvgHeartRate     Int?
  lastUpdated          DateTime
  /// CardioBaselineEntry[] — history entries; stored as Json
  history              Json
  createdAt            DateTime
  updatedAt            DateTime @updatedAt
  /// Soft-delete tombstone — see Program.deletedAt.
  deletedAt            DateTime?

  @@id([userId, canonicalExerciseId])
  @@index([userId])
  // Supports the list orderBy [{ lastUpdated desc }, { canonicalExerciseId desc }].
  @@index([userId, lastUpdated])
  @@map("cardio_baselines")
}

// ============================================================================
// 6. GymExerciseInstance (collection: gymExerciseInstances)
//    Shape: GymExerciseInstance from Workouts models.ts
//    Field names match GymExerciseInstanceSchema (gymProfileId, canonicalExerciseId).
// ============================================================================

model GymExerciseInstance {
  id                  String   @id
  userId              String
  gymProfileId        String
  canonicalExerciseId String
  baseWeightKg        Float?
  /// WeightUnit — "kg" | "lbs"
  weightUnit          String
  /// WeightMode — "absolute" | "relative"
  weightMode          String
  weightIncrementKg   Float?
  isActive            Boolean
  notes               String?
  lastUsedWeightKg    Float?
  createdAt           DateTime
  updatedAt           DateTime @updatedAt
  /// Soft-delete tombstone — see Program.deletedAt.
  deletedAt           DateTime?

  @@index([userId])
  @@index([userId, gymProfileId])
  @@index([userId, canonicalExerciseId])
  // Supports the CRUD factory's default list orderBy [{ createdAt desc }, { id desc }].
  @@index([userId, createdAt])
  @@map("gym_exercise_instances")
}

// ============================================================================
// 7. UserExercise (collection: userExercises)
//    Shape: full CanonicalExercise written by the app into userExercises.
//    The app writes the complete CanonicalExercise payload (including all
//    muscle-group, equipment, and tracking fields) when users create exercises.
// ============================================================================

model UserExercise {
  id                    String   @id
  userId                String
  name                  String
  description           String
  /// TrackingMode — "weightlifting" | "cardio" | "stretching"
  category              String
  /// ExerciseSubcategory — "compound" | "isolation" | "machine" | "freeweight" |
  ///   "bodyweight" | "cable" | "treadmill" | "bike" | "rowing" | "elliptical" |
  ///   "stairmaster" | "outdoor_running" | "outdoor_walking" | "outdoor_cycling" |
  ///   "jump_rope" | "isometric" | "flexibility"
  /// When the stored value is null, the server must infer subcategory before
  /// responding using inferExerciseSubcategory(category, equipmentType).
  subcategory           String?
  /// MuscleGroup[] — primary muscle groups; Postgres text array
  primaryMuscleGroups   String[]
  /// MuscleGroup[] — secondary muscle groups; Postgres text array
  secondaryMuscleGroups String[]
  /// EquipmentType — "barbell" | "dumbbell" | "kettlebell" | "cable" | "machine" |
  ///   "bodyweight" | "resistance_band" | "squat_rack" | "bench" | "pull_up_bar" |
  ///   "plate_loaded_machine" | "smith_machine" | "treadmill" | "stationary_bike" |
  ///   "rowing_machine" | "elliptical" | "stairmaster" | "jump_rope" | "none" | "other"
  equipmentType         String
  /// String[] — specific equipment IDs required (e.g. "olympic_barbell")
  requiredEquipment     String[]
  isBodyweight          Boolean
  isUnilateral          Boolean
  defaultRestTimerSec   Int
  /// WeightMode — "absolute" | "relative"
  defaultWeightMode     String
  illustrationUrl       String
  /// Record<string, unknown> — arbitrary metadata; stored as Json
  metadata              Json
  minimumIncrementKg    Float
  /// ExerciseSource — "library" | "user_created" | "ai_generated_freestyle"
  source                String
  /// ExerciseTrackingMode — "reps" | "timed" | "cardio" | "stretch"
  trackingMode          String?
  isActive              Boolean
  createdAt             DateTime
  updatedAt             DateTime @updatedAt

  @@index([userId])
  // Supports the CRUD factory's default list orderBy [{ createdAt desc }, { id desc }].
  @@index([userId, createdAt])
  @@map("user_exercises")
}

// ============================================================================
// 8. ExerciseAlias (collection: exerciseAliases)
//    Shape: ExerciseAlias from Workouts models.ts
// ============================================================================

model ExerciseAlias {
  id                  String   @id
  userId              String
  alias               String
  normalizedAlias     String
  canonicalExerciseId String
  equipmentType       String?
  gymProfileId        String?
  /// ExerciseAliasSource — "scan" | "manual" | "ai_match"
  source              String
  createdAt           DateTime
  updatedAt           DateTime @updatedAt
  /// Soft-delete tombstone — see Program.deletedAt.
  deletedAt           DateTime?

  @@index([userId])
  @@index([userId, canonicalExerciseId])
  @@index([userId, normalizedAlias])
  // Supports the CRUD factory's default list orderBy [{ createdAt desc }, { id desc }].
  @@index([userId, createdAt])
  @@map("exercise_aliases")
}

// ============================================================================
// 9. Week (collection: weeks)
//    Shape: WeekDocument from Workouts models.ts
//    Composite PK: (userId, weekIso) — there is exactly one week doc per user per ISO week.
//    Sub-documents aiRetrospective, deterministicSnapshot, userAnnotations stored as Json
//    (they are loosely-typed in WeekDocument as `unknown`).
//    Conversation sub-sub-collection is NOT stored here (fetched lazily — see syncConfig.ts note).
// ============================================================================

// REST responses must synthesize id = weekIso when returning Week documents —
// the app's WeekDocument interface requires an `id` field equal to weekIso.
// There is intentionally no `id` column in this table; the composite PK is
// (userId, weekIso).
model Week {
  userId                   String
  weekIso                  String
  /// Frozen deterministic snapshot for the AI retrospective — shape varies by surface; Json
  deterministicSnapshot    Json?
  /// AI retrospective deck data — shape varies; Json (not a separate model — avoids over-relationalizing)
  aiRetrospective          Json?
  /// User annotations on the week — free-form; Json
  userAnnotations          Json?
  /// forward-spec — not yet written by any app path
  conversationUpdatedAt    DateTime?
  /// forward-spec — not yet written by any app path
  hasConversation          Boolean?
  /// forward-spec — not yet written by any app path
  lastConversationThreadId String?
  createdAt                DateTime?
  updatedAt                DateTime  @updatedAt

  @@id([userId, weekIso])
  @@index([userId])
  @@map("weeks")
}

// ============================================================================
// 10. AiAuditLogEntry (collection: aiAuditLog)
//     Shape: AiAuditLogEntry from Workouts models.ts
//     The app stores sourceRef, snapshotInline, aiOutput, diff as top-level
//     document fields; they are flattened into four columns here (not collapsed
//     into a single payload Json blob).
//     'timestamp' matches the app field name (was 'at' — renamed for parity).
// ============================================================================

model AiAuditLogEntry {
  id          String   @id
  userId      String
  timestamp   DateTime
  /// SuggestionSource — which AI surface produced this entry
  surface     String
  modelTier   String
  snapshotRef String?
  /// "auto_applied" | "user_applied" | "user_dismissed" | "user_overrode"
  action      String
  persisted   Boolean
  /// AiSuggestionSourceRef — describes the input context that triggered the AI call
  sourceRef       Json
  /// Full deterministic snapshot captured at suggestion time (may be large); null if not captured
  snapshotInline  Json?
  /// Raw AI model output (suggestions, reasoning, metadata)
  aiOutput        Json
  /// Delta between previous state and applied suggestion; null if not applied
  diff            Json?

  @@index([userId])
  @@index([userId, timestamp])
  @@index([userId, surface])
  @@map("ai_audit_log")
}

// ============================================================================
// 11. InjuryRecord (collection: injuries)
//     Shape: InjuryRecord from Workouts models.ts
// ============================================================================

model InjuryRecord {
  id          String   @id
  userId      String
  muscleGroup String
  description String
  isActive    Boolean
  createdAt   DateTime
  /// SERVER-MANAGED — not sent by the client; stripped by the app's Zod on read.
  /// Kept intentionally for sync ordering and audit purposes.
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([userId, isActive])
  @@map("injury_records")
}

// ============================================================================
// 12. ConversationRollingSummary (singleton per user — NOT a collection)
//     Shape: ConversationRollingSummaryDoc from Workouts models.ts
//     userId IS the PK (one row per user).
//     entries (ConversationRollingSummaryEntry[]) stored as Json.
// ============================================================================

model ConversationRollingSummary {
  /// userId is the PK — one summary document per user
  userId    String   @id
  /// ConversationRollingSummaryEntry[] — stored as Json
  entries   Json
  updatedAt DateTime @updatedAt

  @@map("conversation_rolling_summaries")
}

// ============================================================================
// 13. MetricBasketSnapshotRecord (collection: metricBasketSnapshots)
//     Shape: MetricBasketSnapshotRecord from @hollis-studio/contracts/progression/metrics
//     Firestore path: users/{uid}/metricBasketSnapshots
//
//     Record fields (scalars, queryable):
//       id            — caller-provided composite key:
//                       "{exerciseId}__{captureKind}__{sourceSessionId|timestamp}"
//       exerciseId    — the canonical exercise this snapshot covers
//       capturedAt    — when the basket was computed (queryable; app filters by date)
//       captureKind   — "manual" | "pre_session" | "post_session"
//       sourceSessionId — the session that triggered capture (optional)
//
//     snapshot column:
//       Stored as Json (MetricBasketSnapshot shape):
//         { exerciseId, capturedAt?, e1rmGated?, bestQualifyingSet?,
//           relativeStrengthScore?, repRangePivot? }
//       The nested e1rmGated/BQS/RSS/pivot fields are deeply nested objects
//       with no stable query patterns — Json is appropriate here.
// ============================================================================

model MetricBasketSnapshotRecord {
  id              String   @id
  userId          String
  /// The canonical exercise this snapshot covers
  exerciseId      String
  capturedAt      DateTime
  /// MetricBasketSnapshotCaptureKind — "manual" | "pre_session" | "post_session"
  captureKind     String
  /// Session that triggered capture (null for manual/history snapshots)
  sourceSessionId String?
  /// MetricBasketSnapshot payload — deeply nested; stored as Json
  snapshot        Json
  /// SERVER-MANAGED — not sent by the client; stripped by the app's Zod on read.
  /// Kept intentionally for sync ordering and audit purposes.
  createdAt       DateTime
  /// Soft-delete tombstone — see Program.deletedAt.
  deletedAt       DateTime?

  @@index([userId])
  @@index([userId, exerciseId])
  @@index([userId, sourceSessionId])
  // Supports the ?since filter (where capturedAt >= …).
  @@index([userId, capturedAt])
  // Supports the CRUD factory's default list orderBy [{ createdAt desc }, { id desc }].
  @@index([userId, createdAt])
  @@map("metric_basket_snapshots")
}

// ============================================================================
// 14. UserProfile (singleton per user — path: users/{uid})
//     Shape: UserProfile + UserSettings + UserEntitlements from src/types/models/user.ts
//     One row per user; userId IS the PK (mirrors Firestore singleton doc pattern).
//     settings and entitlements are stored as Json — they are deeply nested, rarely
//     queried individually, and evolve frequently. Scalar fields that ARE queried
//     (fcmDeviceToken for push scheduling, smartReaderFreeUsesRemaining for gates)
//     are promoted to columns.
// ============================================================================

model UserProfile {
  /// userId is the PK — one profile per user (mirrors Firestore users/{uid} singleton).
  userId                      String    @id
  displayName                 String
  email                       String?
  /// Epoch-ms timestamp stored as Float (double precision) to avoid int4 overflow.
  /// Float represents integer epoch-ms exactly below 2^53.
  fcmDeviceToken              String?
  lastFcmTokenUpdate          DateTime?
  smartReaderFreeUsesRemaining Int?
  lastReviewPromptAt          DateTime?
  /// UserSettings — deeply nested, rarely column-queried; stored as Json
  settings                    Json
  /// UserEntitlements — optional, deeply nested; stored as Json
  entitlements                Json?
  createdAt                   DateTime
  updatedAt                   DateTime  @updatedAt

  @@map("user_profiles")
}

// ============================================================================
// 15. PlateauCoachingArtifact (collection: plateauCoaching)
//     Shape: PlateauCoachingArtifact from src/types/models/ai.ts
//     Path: users/{uid}/plateauCoaching/{plateauId}
//     Read-only on client via loadPlateauCoachingArtifact; written by Cloud Functions.
// ============================================================================

model PlateauCoachingArtifact {
  id           String    @id
  userId       String
  exerciseId   String
  detectedAt   DateTime
  narrative    String
  /// String[] — root causes identified by the AI coach; Postgres text array
  rootCauses   String[]
  /// String[] — AI recommendations; Postgres text array
  recommendations String[]
  dismissedAt  DateTime?
  /// { input?: number; output?: number } — token counts from the AI call; stored as Json
  tokenCount   Json?
  createdAt    DateTime
  updatedAt    DateTime  @updatedAt
  /// Soft-delete tombstone — see Program.deletedAt.
  deletedAt    DateTime?

  @@index([userId])
  @@index([userId, exerciseId])
  @@index([userId, detectedAt])
  @@map("plateau_coaching_artifacts")
}

// ============================================================================
// 16. CancellationFeedback (collection: cancellationFeedback)
//     Shape: from src/services/cancellationFeedback.ts
//     Path: users/{uid}/cancellationFeedback (addDoc — auto-id, append-only).
//     option = CancellationFeedbackOption enum value.
//     No updatedAt — records are immutable once written.
// ============================================================================

model CancellationFeedback {
  id        String  @id
  userId    String
  /// CancellationFeedbackOption enum value
  option    String
  detail    String?
  createdAt DateTime

  @@index([userId])
  @@index([userId, createdAt])
  @@map("cancellation_feedback")
}

// ============================================================================
// 17. SmartBuilderDraft — singleton draft per user
//     Shape: mirrors the Firestore singleton at users/{uid}/smartBuilderDraft
//     userId IS the PK (one draft per user, upserted in-place).
//     payload stores the full in-progress program builder state as a Json blob
//     (program skeleton, day configuration, exercise selections, AI suggestions)
//     that the client reconstitutes on re-open.
// ============================================================================

model SmartBuilderDraft {
  /// userId is the PK — one draft per user (singleton, upserted on every save)
  userId    String   @id
  /// Full builder state blob — ProgramDraft shape validated by the app's Zod schema at read/write
  payload   Json
  createdAt DateTime
  updatedAt DateTime @updatedAt

  @@map("smart_builder_drafts")
}

// ============================================================================
// 18. AiTokenUsage — monthly AI token telemetry per user
//     Shape: mirrors Firestore users/{uid}/aiUsage/{yyyy-mm} documents.
//     Each doc stores a `tokens` map of feature → counter (Record<string, number>)
//     as confirmed by tokenUsage.ts (raw['tokens'] is Record<string, unknown>,
//     each value cast to number). The Json column stores that same map verbatim.
//     Unique constraint on (userId, month) mirrors the Firestore doc-id pattern.
// ============================================================================

model AiTokenUsage {
  id        String   @id
  userId    String
  /// ISO month key — "yyyy-mm" (matches Firestore doc id)
  month     String
  /// Record<string, number> — feature → token count map (e.g. { smart_builder: 1200, plateau_coach: 400 })
  tokens    Json
  createdAt DateTime
  updatedAt DateTime @updatedAt

  @@unique([userId, month])
  @@index([userId])
  @@map("ai_token_usage")
}

// ============================================================================
// 19. SmartReaderUsage — monthly free-use counter for Smart Reader (equipment recognition)
//     Tracks non-entitled usage per (userId, month) so the server can enforce
//     SMART_READER_FREE_USES limit without relying on client-side state.
//     Entitled users (hollisIntelligence) bypass this table entirely.
//     month format: "yyyy-mm" (matches AiTokenUsage.month convention).
// ============================================================================

model SmartReaderUsage {
  /// userId is part of the composite PK — one row per user per calendar month.
  userId    String
  /// ISO month key — "yyyy-mm"
  month     String
  /// Number of Smart Reader calls made this month (non-entitled path only).
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@id([userId, month])
  @@index([userId])
  @@map("smart_reader_usage")
}

// ============================================================================
// 20. ExerciseEmbeddingCache — global (not user-scoped) semantic search cache
//     Avoids re-embedding the static CanonicalExercise catalog on every
//     semantic search call. Keyed by (canonicalExerciseId, modelVersion) so that
//     a model upgrade automatically produces new embeddings while old ones remain.
//     sourceTextHash (SHA-256 of the concatenated embedding source text) allows
//     cache invalidation when exercise name/description changes without a model bump.
// ============================================================================

model ExerciseEmbeddingCache {
  id                  String   @id
  /// Canonical exercise slug this embedding covers (e.g. "cable_bicep_curl")
  canonicalExerciseId String
  /// Embedding model version string (e.g. "text-embedding-004")
  modelVersion        String
  /// SHA-256 hex of the text used to generate the embedding — for cache invalidation
  sourceTextHash      String
  /// Raw embedding vector — Float[] (double precision array in Postgres)
  embedding           Float[]
  createdAt           DateTime

  @@unique([canonicalExerciseId, modelVersion])
  @@map("exercise_embedding_cache")
}

// ============================================================================
// 14. CanonicalExercise — global catalog (NOT user-scoped)
//     Shape: CanonicalExercise from Workouts models.ts + CanonicalExerciseSchema
//     NOT in SYNCED_COLLECTIONS — read-only reference data.
//     Seed: prisma/seed-exercises.ts — reads hollis-workouts/scripts/data/exercises.json
//       and upserts in batches. Run: npm run prisma:seed
//     TODO(W5f): Add admin write endpoint if catalog needs server-side updates.
// ============================================================================

model CanonicalExercise {
  /// Exercise slug ID (e.g. "cable_bicep_curl")
  id                    String   @id
  name                  String
  description           String
  /// TrackingMode — "weightlifting" | "cardio" | "stretching"
  category              String
  /// ExerciseSubcategory — "compound" | "isolation" | "machine" | "freeweight" |
  ///   "bodyweight" | "cable" | "treadmill" | "bike" | "rowing" | "elliptical" |
  ///   "stairmaster" | "outdoor_running" | "outdoor_walking" | "outdoor_cycling" |
  ///   "jump_rope" | "isometric" | "flexibility"
  /// When the stored value is null, the server must infer subcategory before
  /// responding using inferExerciseSubcategory(category, equipmentType).
  subcategory           String?
  /// MuscleGroup[] — Postgres text array
  primaryMuscleGroups   String[]
  /// MuscleGroup[] — Postgres text array
  secondaryMuscleGroups String[]
  /// EquipmentType — "barbell" | "dumbbell" | "kettlebell" | "cable" | "machine" |
  ///   "bodyweight" | "resistance_band" | "squat_rack" | "bench" | "pull_up_bar" |
  ///   "plate_loaded_machine" | "smith_machine" | "treadmill" | "stationary_bike" |
  ///   "rowing_machine" | "elliptical" | "stairmaster" | "jump_rope" | "none" | "other"
  equipmentType         String
  /// String[] — specific equipment IDs required
  requiredEquipment     String[]
  isBodyweight          Boolean
  isUnilateral          Boolean
  defaultRestTimerSec   Int
  /// WeightMode — "absolute" | "relative"
  defaultWeightMode     String
  illustrationUrl       String
  /// Record<string, unknown> — arbitrary catalog metadata; stored as Json
  metadata              Json
  minimumIncrementKg    Float
  /// ExerciseSource — "library" | "user_created" | "ai_generated_freestyle"
  source                String
  isActive              Boolean
  /// ExerciseTrackingMode — "reps" | "timed" | "cardio" | "stretch"
  trackingMode          String?
  createdAt             DateTime

  @@index([equipmentType])
  @@index([category])
  @@index([isActive])
  @@map("canonical_exercises")
}
