{
  "name": "@hollis/workouts-server",
  "version": "0.1.0-alpha.0",
  "description": "Hollis Workouts Server — REST API backend replacing Firebase Firestore (Express + Prisma + Postgres + ECS Fargate)",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@hollis/auth-client": "file:../hollis-shared/packages/auth-client",
    "@hollis/contracts": "file:../hollis-shared/packages/contracts",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.6.0",
    "@types/pg": "^8.20.0",
    "dotenv": "^16.6.1",
    "express": "5.2.1",
    "express-rate-limit": "^8.5.1",
    "jsonwebtoken": "9.0.3",
    "pg": "^8.20.0",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.2",
    "prisma": "^7.6.0",
    "tsx": "^4.21.0",
    "typescript": "5.9.2"
  }
}
